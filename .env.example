# =====================================================================
# Solar Dashboard — environment configuration
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# =====================================================================

# --- Data source --------------------------------------------------
# `mock` (default in dev when SEMS creds missing) | `sems` (real)
DATA_SOURCE=mock

# --- SEMS portal credentials (only when DATA_SOURCE=sems) -------------
# Use the OWNER-tier account. Installer / SSO accounts cannot CrossLogin.
# Note: logging into the SEMS web portal with this same account WILL
# invalidate the dashboard's session.
SEMS_ACCOUNT=
SEMS_PASSWORD=
# auto | eu | us | au | hk  (pin to skip the redirect dance)
SEMS_REGION=auto
# auto | inverted  — flip if charging shows as discharge after first sunrise
SEMS_BATTERY_SIGN=auto
# auto | inverted  — flip if exporting to grid shows as importing
SEMS_GRID_SIGN=auto

# --- Dashboard auth (NextAuth credentials gate) ----------------------
# A bcrypt hash. Generate with:  node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# IMPORTANT: wrap the value in single quotes — bcrypt hashes contain `$` segments
# that dotenv would otherwise try to expand as variables.
DASHBOARD_PASSWORD_HASH=''
# Required by NextAuth. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Token-at-rest encryption ----------------------------------------
# 32 bytes hex. Generate with:  openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# --- Prisma -----------------------------------------------------------
DATABASE_URL=file:./data/solar.db
# Note: file: paths are resolved relative to prisma/schema.prisma, so this
# resolves to ./prisma/data/solar.db at the repo root.

# --- Sampler ---------------------------------------------------------
# Set to `false` to disable the in-process sampler (e.g. when running
# multiple Next.js replicas — only one should sample).
ENABLE_SAMPLER=true

# --- Logging ---------------------------------------------------------
LOG_LEVEL=info
