// Production schema (Postgres). See prisma/schema.prisma for the development
// SQLite variant. The two are kept in sync — only the `datasource db` block
// differs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plant {
  id         String   @id
  name       String
  capacityKw Float
  tz         String?
  status     String   @default("offline")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sample {
  id        Int      @id @default(autoincrement())
  plantId   String
  ts        DateTime
  pvKw      Float
  loadKw    Float
  batteryKw Float
  gridKw    Float
  socPct    Float?

  @@index([plantId, ts])
  @@unique([plantId, ts])
}

model Alert {
  id         String    @id
  plantId    String
  severity   String
  code       String
  message    String
  raisedAt   DateTime
  resolvedAt DateTime?

  @@index([plantId, raisedAt])
}

model SemsSession {
  id          String   @id @default("singleton")
  region      String
  apiHost     String
  tokenCipher String
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt
}
